u7b2c\u4e00\u7bc7\u6587\u7ae0          </li> </ul>"},{"location":"blog/tags/#tag:\u6280\u672f\u670d\u52a1\u4e2d\u65ad","title":"\u6280\u672f\u670d\u52a1\u4e2d\u65ad","text":"<ul> <li>            GitHub \u6682\u65f6\u53d6\u6d88\u672a\u767b\u5f55\u7528\u6237\u4ece\u4e2d\u56fd\u8bbf\u95ee\u7684\u9650\u5236          </li> </ul>"},{"location":"blog/tags/#tag:\u7ad9\u70b9\u751f\u6210\u5668","title":"\u7ad9\u70b9\u751f\u6210\u5668","text":"<ul> <li>            \u672c\u7ad9\u7684\u7b2c\u4e00\u7bc7\u6587\u7ae0          </li> </ul>"},{"location":"blog/tags/#tag:\u9759\u6001\u7ad9\u70b9","title":"\u9759\u6001\u7ad9\u70b9","text":"<ul> <li>            \u672c\u7ad9\u7684\u7b2c\u4e00\u7bc7\u6587\u7ae0          </li> </ul>"},{"location":"blog/2025/03/29/First-Article/","title":"\u672c\u7ad9\u7684\u7b2c\u4e00\u7bc7\u6587\u7ae0","text":"<p>\u6700\u8fd1\u840c\u751f\u4e86\u642d\u5efa\u4e2a\u4eba\u535a\u5ba2\u7684\u60f3\u6cd5\uff0c\u4f46\u624b\u5934\u6ca1\u6709\u670d\u52a1\u5668\u8d44\u6e90\uff0c\u4e5f\u4e0d\u60f3\u6295\u5165\u8fc7\u591a\u8fd0\u7ef4\u6210\u672c\u2014\u2014\u8fd9\u8ba9\u6211\u7a81\u7136\u60f3\u8d77\u4e4b\u524d\u90e8\u7f72\u8fc7\u7684 Material for MkDocs \u6587\u6863\u6846\u67b6\u3002\u8fd9\u4e2a\u539f\u672c\u7528\u4e8e\u6280\u672f\u6587\u6863\u7684\u5de5\u5177\uff0c\u6216\u8bb8\u6b63\u662f\u6211\u9700\u8981\u7684\u6781\u7b80\u535a\u5ba2\u89e3\u51b3\u65b9\u6848\u3002</p>","tags":["MkDocs","\u535a\u5ba2\u642d\u5efa","\u9759\u6001\u7ad9\u70b9","\u7ad9\u70b9\u751f\u6210\u5668","\u4e91\u539f\u751f"]},{"location":"blog/2025/03/29/First-Article/#\u4e3a\u4ec0\u4e48\u9009\u7528-material-for-mkdocs","title":"\u4e3a\u4ec0\u4e48\u9009\u7528 Material for MkDocs\uff1f","text":"","tags":["MkDocs","\u535a\u5ba2\u642d\u5efa","\u9759\u6001\u7ad9\u70b9","\u7ad9\u70b9\u751f\u6210\u5668","\u4e91\u539f\u751f"]},{"location":"blog/2025/03/29/First-Article/#1-material-design-\u7684\u7eaf\u7cb9\u7f8e\u611f","title":"1. Material Design \u7684\u7eaf\u7cb9\u7f8e\u611f","text":"<p>\u4f5c\u4e3a Google \u8bbe\u8ba1\u8bed\u8a00\u7684\u5fe0\u5b9e\u7231\u597d\u8005\uff0cMaterial for MkDocs \u5929\u751f\u5177\u5907 \u6c89\u6d78\u5f0f\u7684\u89c6\u89c9\u5c42\u6b21\u3002\u6070\u5230\u597d\u5904\u7684\u9634\u5f71\u8fc7\u6e21\u3001\u4e1d\u6ed1\u7684\u7ec4\u4ef6\u4ea4\u4e92\uff0c\u4ee5\u53ca\u81ea\u9002\u5e94\u6697\u8272\u6a21\u5f0f\uff0c\u8ba9\u5199\u4f5c\u4f53\u9a8c\u4e0e\u5185\u5bb9\u5448\u73b0\u90fd\u5145\u6ee1\u73b0\u4ee3\u611f\u3002</p>","tags":["MkDocs","\u535a\u5ba2\u642d\u5efa","\u9759\u6001\u7ad9\u70b9","\u7ad9\u70b9\u751f\u6210\u5668","\u4e91\u539f\u751f"]},{"location":"blog/2025/03/29/First-Article/#2-\u4f4e\u4ee3\u7801\u9ad8\u5b9a\u5236\u7684\u5e73\u8861\u672f","title":"2. \u4f4e\u4ee3\u7801\u9ad8\u5b9a\u5236\u7684\u5e73\u8861\u672f","text":"<p>\u901a\u8fc7\u7b80\u5355\u7684 <code>mkdocs.yml</code> \u914d\u7f6e\u6587\u4ef6\u5373\u53ef\u5b9e\u73b0\uff1a</p> <ul> <li>\u81ea\u5b9a\u4e49\u5bfc\u822a\u680f\u4e0e\u9875\u811a</li> <li>\u96c6\u6210\u8bc4\u8bba\u7cfb\u7edf\uff08\u5982 Giscus\uff09</li> <li>\u6dfb\u52a0 SEO \u4f18\u5316\u6807\u7b7e</li> <li>\u6269\u5c55 Markdown \u8bed\u6cd5\u652f\u6301\uff08\u6d41\u7a0b\u56fe\u3001\u6570\u5b66\u516c\u5f0f\u7b49\uff09</li> <li>\u66f4\u591a\u6269\u5c55 / \u81ea\u5b9a\u4e49\u529f\u80fd...</li> </ul> <p>\u65e0\u9700\u524d\u7aef\u77e5\u8bc6\uff0c\u5374\u80fd\u5b9e\u73b0\u4e13\u4e1a\u7ea7\u5b9a\u5236\uff0c\u8fd9\u5bf9\u6280\u672f\u51fa\u8eab\u7684\u5199\u4f5c\u8005\u5c24\u4e3a\u53cb\u597d\u3002</p>","tags":["MkDocs","\u535a\u5ba2\u642d\u5efa","\u9759\u6001\u7ad9\u70b9","\u7ad9\u70b9\u751f\u6210\u5668","\u4e91\u539f\u751f"]},{"location":"blog/2025/03/29/First-Article/#3-\u9759\u6001\u7f51\u7ad9\u7684\u4f18\u96c5\u54f2\u5b66","title":"3. \u9759\u6001\u7f51\u7ad9\u7684\u4f18\u96c5\u54f2\u5b66","text":"<p>\u6240\u6709\u5185\u5bb9\u901a\u8fc7 Markdown \u4e66\u5199\uff0c<code>mkdocs build</code> \u547d\u4ee4\u4e00\u952e\u751f\u6210\u7eaf\u9759\u6001\u9875\u9762\uff0c\u53ef\u76f4\u63a5\u90e8\u7f72\u81f3 <code>GitHub Pages</code> / <code>Vercel</code> \u7b49\u514d\u8d39\u5e73\u53f0\u3002\u6ca1\u6709\u6570\u636e\u5e93\u7ef4\u62a4\u538b\u529b\uff0c\u6ca1\u6709\u63d2\u4ef6\u6f0f\u6d1e\u98ce\u9669\uff0c\u53ea\u6709 \u300c\u5185\u5bb9\u5373\u8d44\u4ea7\u300d \u7684\u6781\u7b80\u4e3b\u4e49\u3002</p>","tags":["MkDocs","\u535a\u5ba2\u642d\u5efa","\u9759\u6001\u7ad9\u70b9","\u7ad9\u70b9\u751f\u6210\u5668","\u4e91\u539f\u751f"]},{"location":"blog/2025/03/29/First-Article/#\u4e3a\u4ec0\u4e48\u4e0d\u7528-wordpress","title":"\u4e3a\u4ec0\u4e48\u4e0d\u7528 WordPress\uff1f","text":"<ol> <li>\u6210\u672c\u654f\u611f\uff1a\u4e00\u53f0 24 \u5c0f\u65f6\u5728\u7ebf\u7684\u4e91\u670d\u52a1\u5668\u5e74\u8d39\u8db3\u591f\u4e70\u4e09\u672c\u6280\u672f\u4e66\u7c4d\uff0c\u800c\u9759\u6001\u6258\u7ba1\u65b9\u6848\u771f\u6b63\u5b9e\u73b0\u96f6\u6210\u672c\u8fd0\u7ef4 \uff08\u5176\u5b9e\u4e3b\u8981\u539f\u56e0\u5c31\u662f\uff1a\u6211\u662f\u5b66\u751f\u515a\uff09</li> <li>\u51cf\u6cd5\u539f\u5219\uff1a\u5f53 80% \u7684\u535a\u5ba2\u529f\u80fd\u53ea\u662f\u5c55\u793a\u6587\u7ae0\u65f6\uff0c\u4e3a\u4f55\u8981\u627f\u53d7\u63d2\u4ef6\u66f4\u65b0\u3001\u540e\u53f0\u7ba1\u7406\u3001\u6027\u80fd\u8c03\u4f18\u7684\u91cd\u8d1f\uff1f</li> <li>\u7248\u672c\u63a7\u5236\u57fa\u56e0\uff1a\u6240\u6709\u6587\u7ae0\u4ee5 <code>.md</code> \u6587\u4ef6\u5b58\u50a8\u4e8e Git \u4ed3\u5e93\uff0c\u5929\u7136\u5177\u5907\u7248\u672c\u56de\u6eaf\u3001\u591a\u7aef\u540c\u6b65\u80fd\u529b\uff0c\u5199\u4f5c\u8fc7\u7a0b\u672c\u8eab\u5c31\u662f\u4ee3\u7801\u63d0\u4ea4\u53f2</li> </ol>","tags":["MkDocs","\u535a\u5ba2\u642d\u5efa","\u9759\u6001\u7ad9\u70b9","\u7ad9\u70b9\u751f\u6210\u5668","\u4e91\u539f\u751f"]},{"location":"blog/2025/03/29/First-Article/#\u5173\u4e8e\u8fd9\u4e2a\u535a\u5ba2\u7684\u5b9e\u9a8c\u6027\u5c1d\u8bd5","title":"\u5173\u4e8e\u8fd9\u4e2a\u535a\u5ba2\u7684\u5b9e\u9a8c\u6027\u5c1d\u8bd5","text":"<p>\u4f5c\u4e3a\u6280\u672f\u7231\u597d\u8005\uff0c\u6211\u59cb\u7ec8\u76f8\u4fe1 \u300c\u8f93\u51fa\u662f\u6700\u597d\u7684\u8f93\u5165\u300d\u3002\u8fd9\u91cc\u5c06\u4e3b\u8981\u8bb0\u5f55\uff1a</p> <ul> <li> \u6280\u672f\u539f\u7406\u5206\u4eab\uff08WinAPI \u5b9e\u8df5 / \u7f16\u7a0b\u6280\u5de7 / \u4e91\u539f\u751f\u6784\u5efa \u7b49\uff09</li> <li> \u6548\u7387\u5de5\u5177\u94fe\u5b9e\u8df5</li> <li> \u5076\u5c14\u8de8\u754c\u7684\u4eba\u6587\u601d\u8003</li> </ul> <p>\u6211\u4e5f\u540c\u65f6\u5728\u5b9e\u8df5\u4e2d\u5b66\u4e60\uff0c\u8fd9\u4e5f\u5370\u8bc1\u4e86 \u300cAnyway, keep learning.\u300d \u8fd9\u53e5\u8bdd\u3002</p> <p>\u5c3d\u7ba1\u8fd9\u662f\u9996\u6b21\u5c1d\u8bd5\u535a\u5ba2\u521b\u4f5c\uff0c\u4f46\u6211\u66f4\u613f\u610f\u5c06\u5176\u89c6\u4e3a \u300c\u6570\u5b57\u82b1\u56ed\u300d \u7684\u64ad\u79cd\u2014\u2014\u4e0d\u8ffd\u6c42\u65e5\u66f4\u7684\u8282\u594f\uff0c\u53ea\u805a\u7126\u4e8e\u6301\u7eed\u7684\u77e5\u8bc6\u6c89\u6dc0\u4e0e\u91cd\u6784\u3002\u5982\u679c\u60a8\u5728\u9605\u8bfb\u4e2d\u53d1\u73b0\u4efb\u4f55\u6280\u672f\u8c2c\u8bef\uff0c\u6216\u662f\u6709\u60f3\u63a2\u8ba8\u7684\u8bdd\u9898\uff0c\u6b22\u8fce\u8df3\u8f6c\u81f3  \u5173\u4e8e\u6211 \u9875\u9762\u83b7\u53d6\u8054\u7cfb\u65b9\u5f0f\u4e0e\u6211\u4ea4\u6d41\u3002</p> <p>\u9759\u5f85\u601d\u60f3\u7684\u79cd\u5b50\u5728\u6b64\u751f\u6839\u53d1\u82bd\u3002\ud83c\udf31</p>","tags":["MkDocs","\u535a\u5ba2\u642d\u5efa","\u9759\u6001\u7ad9\u70b9","\u7ad9\u70b9\u751f\u6210\u5668","\u4e91\u539f\u751f"]},{"location":"blog/2025/03/29/First-Article/#\u611f\u8c22-material-for-mkdocs","title":"\u611f\u8c22  Material for MkDocs","text":"<p>\u6700\u540e\uff0c\u611f\u8c22 Material for MkDocs \u7684\u5f00\u53d1\u56e2\u961f\u63d0\u4f9b\u4e86\u7b80\u5355\u6613\u7528\u4e14\u51fa\u8272\u7684 \u9879\u76ee\u6587\u6863 / \u535a\u5ba2 \u5de5\u5177\uff0c\u5176\u5f00\u7bb1\u5373\u7528\u7684\u914d\u7f6e\u6781\u5927\u7b80\u5316\u4e86\u6211\u7684\u90e8\u7f72\u6d41\u7a0b\uff0c\u4f7f\u6211\u53ef\u4ee5\u4e13\u5fc3\u5fd9\u4e8e\u522b\u7684\u4e8b\u60c5\u4e2d\u3002</p> <p>\u540e\u8bb0</p> <p>\u672c\u6587\u5168\u7a0b\u4f7f\u7528 VS Code \u7f16\u8f91\uff0c\u901a\u8fc7 GitHub Actions \u81ea\u52a8\u6784\u5efa\u90e8\u7f72\uff0c\u4f7f\u7528 GitHub Pages \u6258\u7ba1\u2014\u2014\u8fd9\u6216\u8bb8\u5c31\u662f\u9759\u6001\u535a\u5ba2\u7684\u9b45\u529b\u6240\u5728\u3002</p> <p>\u4f7f\u7528 <code>DeepSeek R1</code> \u957f\u601d\u8003\u6a21\u578b\u8f85\u52a9\u64b0\u5199\uff0c\u5176\u5bf9\u6280\u672f\u7ec6\u8282\u7684\u7cbe\u51c6\u6355\u6349\u4e0e\u903b\u8f91\u68b3\u7406\u80fd\u529b\u4ee4\u4eba\u5370\u8c61\u6df1\u523b\uff0c\u592a NB \u4e86\u3002</p>","tags":["MkDocs","\u535a\u5ba2\u642d\u5efa","\u9759\u6001\u7ad9\u70b9","\u7ad9\u70b9\u751f\u6210\u5668","\u4e91\u539f\u751f"]},{"location":"blog/2025/04/13/GitHub-Block-CN-IP/","title":"GitHub \u5c4f\u853d\u4e2d\u56fd\u5730\u533a\u8bbf\u95ee\u7684\u89e3\u51b3\u65b9\u6848","text":"<p>4 \u6708 13 \u65e5 13:00 \u5de6\u53f3\uff0cGitHub \u5c4f\u853d\u4e86\u4e2d\u56fd\u5730\u533a\u7684\u8bbf\u95ee\uff0c\u672a\u767b\u5f55\u7528\u6237\u8bbf\u95ee\u65f6\u4f1a\u89e6\u53d1 <code>HTTP 403 Forbidden</code> \u9519\u8bef\uff0c\u63d0\u793a \u201cAccess to this site has been restricted.\u201d\u3002\u5df2\u767b\u5f55\u7528\u6237\u4e5f\u53ef\u80fd\u4f1a\u53d7\u5230\u9650\u5236\u3002</p> <p>\u4ee5\u4e0b\u662f\u6211\u9a8c\u8bc1\u7684\u4e00\u4e9b\u89e3\u51b3\u65b9\u6848\uff1a</p>","tags":["GitHub"]},{"location":"blog/2025/04/13/GitHub-Block-CN-IP/#1-\u4f7f\u7528\u4ee3\u7406\u670d\u52a1\u5668\u63a8\u8350","title":"1. \u4f7f\u7528\u4ee3\u7406\u670d\u52a1\u5668\uff08\u63a8\u8350\uff09","text":"<p>\u4f7f\u7528\u4ee3\u7406\u5ba2\u6237\u7aef\uff08\u5982 Clash\u3001V2Ray\uff09\uff0c\u8fde\u63a5\u975e\u4e2d\u56fd\u8282\u70b9\uff08\u7f8e\u56fd\u3001\u65e5\u672c\u3001\u65b0\u52a0\u5761\u7b49\uff09\uff0c\u5e76\u5f00\u542f\u7cfb\u7edf\u4ee3\u7406\u5373\u53ef\u7ed5\u8fc7 IP \u5c01\u9501\u3002</p> <p>\u7531\u4e8e\u4f17\u6240\u5468\u77e5\u7684\u539f\u56e0\uff0c\u4e0d\u63d0\u4f9b\u4ee3\u7406\u670d\u52a1\u5668\u63d0\u4f9b\u5546\uff0c\u8bf7\u81ea\u884c\u67e5\u627e\u3002</p>","tags":["GitHub"]},{"location":"blog/2025/04/13/GitHub-Block-CN-IP/#2-\u5229\u7528-bug-\u7ed5\u8fc7\u9650\u5236\u6b64\u65b9\u6cd5\u5df2\u4e0d\u53ef\u7528","title":"2. \u5229\u7528 Bug \u7ed5\u8fc7\u9650\u5236\uff08\u6b64\u65b9\u6cd5\u5df2\u4e0d\u53ef\u7528\uff09","text":"<p>\u4f7f\u7528\u88ab\u5c01\u7981\u7684\u8282\u70b9\uff08\u4f8b\u5982\u4e2d\u56fd\u5927\u9646\u7f51\u7edc\uff09\u8bbf\u95ee https://github.com/login/ \u540e\uff0c GitHub \u4f1a\u5b58\u50a8\u4e00\u4e2a Cookie \uff0c\u8fd9\u65f6\u53ea\u8981\u8fd9\u4e2a Cookie \u4e0d\u88ab\u5220\u9664\uff0c\u518d\u7528\u88ab GitHub \u5c01\u7981\u7684\u8282\u70b9\u8bbf\u95ee GitHub \u5c31\u4e0d\u4f1a\u88ab 403 \u7981\u6b62\u8bbf\u95ee\uff0c\u65e0\u9700\u767b\u5f55 GitHub \u3002\u5982\u679c\u8fd9\u4e2a Cookie \u88ab\u5220\u9664\uff0c GitHub \u8fd8\u4f1a 403 \u7981\u6b62\u8bbf\u95ee\u3002</p> <p>\u8bf4\u4eba\u8bdd\u5c31\u662f\uff1a\u88f8\u8fde GitHub \u5e76\u8bbf\u95ee https://github.com/login/\uff0c\u65e0\u9700\u7406\u4f1a <code>Access to this site has been restricted.</code>\uff0c\u4e4b\u540e\u76f4\u63a5\u8bbf\u95ee <code>github.com</code> \u5373\u53ef\u89e3\u9664\u9650\u5236\u3002</p>","tags":["GitHub"]},{"location":"blog/2025/04/13/GitHub-Block-CN-IP/#3-\u4f7f\u7528\u955c\u50cf\u7ad9","title":"3. \u4f7f\u7528\u955c\u50cf\u7ad9","text":"<p>\u4f7f\u7528\u7c7b\u4f3c\u4e8e KKGitHub \u7684 GitHub \u955c\u50cf\u670d\u52a1\u6765\u89e3\u9664\u9650\u5236\u3002</p> <p>\u58f0\u660e\uff1a\u672c\u6587\u4ec5\u63d0\u4f9b\u6280\u672f\u8ba8\u8bba\uff0c\u4e0d\u63a8\u8350\u5177\u4f53\u5de5\u5177\u6216\u670d\u52a1\u5546\u3002</p> <p>\u90e8\u5206\u65b9\u6cd5\u53ef\u80fd\u968f\u653f\u7b56\u8c03\u6574\u5931\u6548\uff0c\u5982\u679c\u6709\u5176\u4ed6\u65b9\u6cd5\u6b22\u8fce\u5728\u8bc4\u8bba\u533a\u8865\u5145\u3002</p> <p>\u672c\u6587\u64b0\u5199\u5306\u5fd9\uff0c\u5982\u6709\u9519\u8bef\u8bf7\u53ca\u65f6\u6307\u51fa\u3002</p>","tags":["GitHub"]},{"location":"blog/2025/04/14/GitHub-Unblock-CN/","title":"GitHub \u6682\u65f6\u53d6\u6d88\u672a\u767b\u5f55\u7528\u6237\u4ece\u4e2d\u56fd\u8bbf\u95ee\u7684\u9650\u5236","text":"","tags":["GitHub","\u6280\u672f\u670d\u52a1\u4e2d\u65ad"]},{"location":"blog/2025/04/14/GitHub-Unblock-CN/#\u6458\u8981","title":"\u6458\u8981","text":"<p>2025 \u5e74 4 \u6708 13 \u65e5 4:01(UTC+8) \u5de6\u53f3\uff0cGitHub \u56e0\u914d\u7f6e\u53d8\u66f4\u5bfc\u81f4\u672a\u767b\u5f55\u7528\u6237\u4ece\u4e2d\u56fd\u8bbf\u95ee GitHub.com \u65f6\u51fa\u73b0\u8bbf\u95ee\u9650\u5236\u3002\u5df2\u767b\u5f55\u7528\u6237\u4ecd\u53ef\u6b63\u5e38\u8bbf\u95ee\u3002\u8be5\u95ee\u9898\u4e8e  2025 \u5e74 4 \u6708 13 \u65e5 22:55(UTC+8) \u5f97\u5230\u89e3\u51b3\u3002</p>","tags":["GitHub","\u6280\u672f\u670d\u52a1\u4e2d\u65ad"]},{"location":"blog/2025/04/14/GitHub-Unblock-CN/#\u5b98\u65b9\u4e8b\u4ef6\u62a5\u544a\u8bd1\u6587","title":"\u5b98\u65b9\u4e8b\u4ef6\u62a5\u544a\uff08\u8bd1\u6587\uff09","text":"","tags":["GitHub","\u6280\u672f\u670d\u52a1\u4e2d\u65ad"]},{"location":"blog/2025/04/14/GitHub-Unblock-CN/#\u4e8b\u540e\u62a5\u544a-\u6682\u65f6\u53d6\u6d88-\u7981\u6b62\u672a\u767b\u5f55\u7684\u4e2d\u56fd\u7528\u6237\u8bbf\u95ee-github-\u7684\u9650\u5236","title":"[\u4e8b\u540e\u62a5\u544a] \u6682\u65f6\u53d6\u6d88 <code>\u7981\u6b62\u672a\u767b\u5f55\u7684\u4e2d\u56fd\u7528\u6237\u8bbf\u95ee GitHub</code> \u7684\u9650\u5236 <sup>1</sup>","text":"<p>GitHub \u4e8b\u4ef6\u62a5\u544a</p> <p>\u7531\u4e8e\u4e00\u6b21\u914d\u7f6e\u66f4\u6539\u4ea7\u751f\u4e86\u610f\u5916\u5f71\u54cd\uff0c\u4e2d\u56fd\u5730\u533a\u672a\u767b\u5f55\u7528\u6237\u5728\u5c1d\u8bd5\u8bbf\u95ee GitHub.com \u65f6\u66fe\u906d\u9047\u6682\u65f6\u6027\u8bbf\u95ee\u4e2d\u65ad\u3002\u5df2\u767b\u5f55\u7528\u6237\u53ef\u6b63\u5e38\u7ee7\u7eed\u8bbf\u95ee\u7f51\u7ad9\u3002\u5f71\u54cd\u4e8e <code>2025/04/12 20:01(UTC)</code> \u5f00\u59cb\u3002\u5f71\u54cd\u5df2\u4e8e <code>2025/04/13 14:55(UTC)</code> \u7f13\u89e3\u3002</p> <p>\u73b0\u5df2\u64a4\u9500\u5bfc\u81f4\u6b64\u95ee\u9898\u7684\u76f8\u5173\u914d\u7f6e\u66f4\u6539\uff0c\u7528\u6237\u5728\u5c1d\u8bd5\u8bbf\u95ee GitHub.com \u65f6\u4e0d\u5e94\u518d\u9047\u5230\u8bbf\u95ee\u95ee\u9898\u3002</p> <p>\u53d1\u5e03\u4e8e 1 \u5929\u524d - 2025 \u5e74 4 \u6708 12 \u65e5 20:00 UTC</p>","tags":["GitHub","\u6280\u672f\u670d\u52a1\u4e2d\u65ad"]},{"location":"blog/2025/04/14/GitHub-Unblock-CN/#\u5b98\u65b9\u539f\u59cb\u62a5\u544a","title":"\u5b98\u65b9\u539f\u59cb\u62a5\u544a","text":"<p>\u5185\u5bb9\u6765\u6e90\u4e8e GitHub Status \u9875\u9762\u3002</p> <ol> <li> <p>\u539f\u59cb\u62a5\u544a\uff1ahttps://www.githubstatus.com/incidents/jfvgcls9swln \u21a9</p> </li> </ol>","tags":["GitHub","\u6280\u672f\u670d\u52a1\u4e2d\u65ad"]},{"location":"blog/2025/04/14/GitHub-Unblock-CN/#retroactive-access-from-china-temporarily-blocked-for-users-that-were-not-logged-in","title":"[Retroactive] Access from China temporarily blocked for users that were not logged in","text":"<p>Incident Report for GitHub</p>","tags":["GitHub","\u6280\u672f\u670d\u52a1\u4e2d\u65ad"]},{"location":"blog/2025/04/14/GitHub-Unblock-CN/#resolved","title":"Resolved","text":"<p>Due to a configuration change with unintended impact, users that were not logged in who tried to visit GitHub.com from China were temporarily unable to access the site. For users already logged in, they could continue to access the site successfully. Impact started 2025/04/12 at 20:01 UTC. Impact was mitigated 2025/04/13 at 14:55 UTC.</p> <p>The configuration changes that caused this impact have been reversed and users should no longer see problems when trying to access GitHub.com.</p>","tags":["GitHub","\u6280\u672f\u670d\u52a1\u4e2d\u65ad"]},{"location":"blog/2025/04/14/GitHub-Unblock-CN/#posted-1-day-ago-apr-12-2025---2000-utc","title":"Posted 1 day ago. Apr 12, 2025 - 20:00 UTC","text":"","tags":["GitHub","\u6280\u672f\u670d\u52a1\u4e2d\u65ad"]},{"location":"blog/2024/01/01/Example-Article/","title":"Happy new year!","text":"<p>Happy 2024 to everyone. Wishing you all the best!</p> <p>\u795d\u5927\u5bb6 2024 \u65b0\u5e74\u5feb\u4e50\u3002\u795d\u4f60\u4e00\u5207\u987a\u5229\uff01</p> <p>\u76f8\u5173\u94fe\u63a5</p> <p>https://squidfunk.github.io/mkdocs-material</p> <p>https://squidfunk.github.io/mkdocs-material/tutorials/blogs/basic/</p>"},{"location":"blog/archive/2025/","title":"2025","text":""},{"location":"blog/archive/2024/","title":"2024","text":""},{"location":"blog/category/github/","title":"GitHub","text":""},{"location":"blog/category/%E5%BB%BA%E7%AB%99%E6%97%A5%E5%BF%97/","title":"\u5efa\u7ad9\u65e5\u5fd7","text":""},{"location":"blog/category/%E6%8A%80%E6%9C%AF%E5%AE%9E%E8%B7%B5/","title":"\u6280\u672f\u5b9e\u8df5","text":""},{"location":"blog/category/uncategorized/","title":"Uncategorized","text":""}]}